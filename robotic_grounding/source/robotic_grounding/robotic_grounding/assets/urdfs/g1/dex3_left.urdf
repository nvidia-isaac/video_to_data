    <!-- Fingertip frames for IK targets -->
    <link name="left_thumb_tip">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1e-9"/>
            <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
        </inertial>
    </link>
    <joint name="left_thumb_tip_joint" type="fixed">
        <origin xyz="0 -0.035 0" rpy="0 0 0"/>
        <parent link="left_hand_thumb_2_link"/>
        <child link="left_thumb_tip"/>
    </joint>

    <link name="left_index_tip">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1e-9"/>
            <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
        </inertial>
    </link>
    <joint name="left_index_tip_joint" type="fixed">
        <origin xyz="0.035 0 0" rpy="0 0 0"/>
        <parent link="left_hand_index_1_link"/>
        <child link="left_index_tip"/>
    </joint>

    <link name="left_middle_tip">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1e-9"/>
            <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
        </inertial>
    </link>
    <joint name="left_middle_tip_joint" type="fixed">
        <origin xyz="0.035 0 0" rpy="0 0 0"/>
        <parent link="left_hand_middle_1_link"/>
        <child link="left_middle_tip"/>
    </joint>

</robot>
