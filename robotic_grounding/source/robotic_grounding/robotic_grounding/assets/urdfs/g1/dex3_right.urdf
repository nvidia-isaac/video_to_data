<?xml version="1.0"?>
<!-- Dex3 right hand with palm as root (no 6-DOF base joints).
     Load with pinocchio root_joint=FreeFlyer for IK retargeting. -->
<robot name="dex3_right">

    <link name="right_hand_palm_link">
        <inertial>
            <origin xyz="0.06214634836 0.00050869656 -0.00058171093" rpy="0 0 0"/>
            <mass value="0.37283854"/>
            <inertia ixx="0.00027535181027" ixy="0.00001595519465" ixz="-0.00000242161890"
                iyy="0.00053951827219" iyz="0.00000042279435" izz="0.00039623390907"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://g1/right_hand_palm_link.STL"/>
            </geometry>
            <material name="white">
                <color rgba="0.7 0.7 0.7 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <mesh filename="package://g1/right_hand_palm_link.STL"/>
            </geometry>
        </collision>
    </link>

