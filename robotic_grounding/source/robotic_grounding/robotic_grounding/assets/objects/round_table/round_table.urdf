<?xml version="1.0"?>
<robot name="round_table">

  <link name="base">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.013" ixy="0" ixz="0"
               iyy="0.02" iyz="0"
               izz="0.02"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="round_table_scale.stl"/>
      </geometry>
      <material name="black">
        <color rgba="0.14 0.14 0.14 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.0225" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.2" length="0.2"/>
      </geometry>
    </collision>
  </link>

</robot>
