<?xml version="1.0" ?>
<robot name="apple">
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  <link name="object">
    <visual>
      <geometry>
        <mesh filename="apple_collision.obj" scale="1.0 1.0 1.0"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="apple_collision.obj" scale="1.0 1.0 1.0"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
</robot>
